// BotCampaignProfile.db
// 作者: Michael S. Booth, Turtle Rock Studios (www.turtlerockstudios.com)
// 汉化：毛毛的老公(http://tarimren.ysepan.com/)
// 汉化时间：2026年5月20日
// 该数据库对游戏中所有的机器人进行个性化定制
//
//
//----------------------------------------------------------------------------
//
// 以下为机器人参数
//
Default
	Skill = 50
	Aggression = 50
	ReactionTime = 0.3
	AttackDelay = 0
	Teamwork = 75
	WeaponPreference = none
	Cost = 0
	Difficulty = NORMAL
	VoicePitch = 100
	Skin = 0
End

// 释义：
// 默认参数
//	Skill = 50                ;机器人技能（数值大小决定机器人枪法.越大越精准）
//	Aggression = 50           ;机器人攻击性（数值越大越爱冲锋） 
//	ReactionTime = 0.3        ;机器人反应时间（受到攻击或听见枪声时的反应时间.专家级范围为0-0.4）
//	AttackDelay = 0           ;机器人攻击延迟（看到敌人后开火的时间.0为无延迟）
//	Teamwork = 75             ;机器人团队合作能力（数值越大配合程度越高）
//	WeaponPreference = none   ;机器人武器偏好
//	Cost = 0                  ;购买装备及枪械的花费（CZ中有效）
//	Difficulty = NORMAL       ;机器人难度级别            
//	VoicePitch = 100          ;机器人的语音大小
//	Skin = 0                  ;机器人皮肤类型
//End

//----------------------------------------------------------------------------
//
// 二、以下模板项目继承自默认设置（一），并以其设定值对默认设置进行更改
// 模板名称定义了相应类型，被机器人配置文件所使用

// （一）武器偏好模板
//--------------------------------------------------------------------------
// 语法定义（以SonDoll为范例）
//Template SonDoll             ;Template代表开始，SonDoll代表武器偏好模板名称
//	WeaponPreference = m4a1    ;1级优先武器
//	WeaponPreference = ak47    ;2级优先武器
//	WeaponPreference = famas   ;3级优先武器
//	WeaponPreference = galil   ;4级优先武器
//	WeaponPreference = mp5     ;5级优先武器
//End
// 优先级设置说明：尽可能将价格高的武器置于高优先级.如果将ak47和m4a1设置为1级和2级
//               且机器人的金钱数足以同时购买ak47和m4a1时，则会同时购买,造成经济浪费.
//--------------------------------------------------------------------------

//--------------------------------------------------------------------------
Template Rifle
	WeaponPreference = m4a1
	WeaponPreference = ak47
	WeaponPreference = famas
	WeaponPreference = galil
	WeaponPreference = mp5
End

// 释义：
// Template Rifle               ;步枪手模板（Rifle）
//	WeaponPreference = m4a1     ;武器偏好（m4a1）
//	WeaponPreference = ak47     ;武器偏好（ak47）
//	WeaponPreference = famas    ;武器偏好（famas）
//	WeaponPreference = galil    ;武器偏好（galil）
//	WeaponPreference = mp5      ;武器偏好（mp5）
// End
//----------------------------------------------------------------------------

//----------------------------------------------------------------------------
Template RifleT
	WeaponPreference = ak47
	WeaponPreference = m4a1
	WeaponPreference = galil
	WeaponPreference = famas
	WeaponPreference = mp5
End

// 释义：
// Template RifleT              ;重型步枪手模板（RifleT）
//	WeaponPreference = m4a1     ;武器偏好（m4a1）
//	WeaponPreference = ak47     ;武器偏好（ak47）
//	WeaponPreference = famas    ;武器偏好（famas）
//	WeaponPreference = galil    ;武器偏好（galil）
//	WeaponPreference = mp5      ;武器偏好（mp5）
// End
//----------------------------------------------------------------------------

//----------------------------------------------------------------------------
Template Punch
	WeaponPreference = aug
	WeaponPreference = sg552
	WeaponPreference = famas
	WeaponPreference = galil
	WeaponPreference = mp5
End

// 释义：
// Template Punch               ;冲锋手模板（Punch）
//	WeaponPreference = m4a1     ;武器偏好（m4a1）
//	WeaponPreference = ak47     ;武器偏好（ak47）
//	WeaponPreference = famas    ;武器偏好（famas）
//	WeaponPreference = galil    ;武器偏好（galil）
//	WeaponPreference = mp5      ;武器偏好（mp5）
// End
//----------------------------------------------------------------------------

//----------------------------------------------------------------------------
Template Sniper
	WeaponPreference = awp
	WeaponPreference = sg550
	WeaponPreference = g3sg1
	WeaponPreference = scout
	WeaponPreference = famas
	WeaponPreference = galil
	WeaponPreference = mp5
End

// 释义：
// Template Sniper              ;狙击手模板（Sniper）
//	WeaponPreference = m4a1     ;武器偏好（m4a1）
//	WeaponPreference = ak47     ;武器偏好（ak47）
//	WeaponPreference = famas    ;武器偏好（famas）
//	WeaponPreference = galil    ;武器偏好（galil）
//	WeaponPreference = mp5      ;武器偏好（mp5）
// End
//----------------------------------------------------------------------------

//----------------------------------------------------------------------------
Template Power
	WeaponPreference = m249
	WeaponPreference = xm1014
	WeaponPreference = m3
	WeaponPreference = famas
	WeaponPreference = galil
	WeaponPreference = mp5
End

// 释义：
// Template Power               ;机枪手模板（power）
//	WeaponPreference = m4a1     ;武器偏好（m4a1）
//	WeaponPreference = ak47     ;武器偏好（ak47）
//	WeaponPreference = famas    ;武器偏好（famas）
//	WeaponPreference = galil    ;武器偏好（galil）
//	WeaponPreference = mp5      ;武器偏好（mp5）
// End
//----------------------------------------------------------------------------

//----------------------------------------------------------------------------
Template Shotgun
	WeaponPreference = xm1014
	WeaponPreference = m3
	WeaponPreference = famas
	WeaponPreference = galil
	WeaponPreference = mp5
End

// 释义：
// Template Shotgun             ;霰弹枪手模板（shotgun）
//	WeaponPreference = m4a1     ;武器偏好（m4a1）
//	WeaponPreference = ak47     ;武器偏好（ak47）
//	WeaponPreference = famas    ;武器偏好（famas）
//	WeaponPreference = galil    ;武器偏好（galil）
//	WeaponPreference = mp5      ;武器偏好（mp5）
// End
//----------------------------------------------------------------------------

//----------------------------------------------------------------------------
Template Shield
	WeaponPreference = shield
	WeaponPreference = m4a1			// in case shield is disallowed
	WeaponPreference = ak47
	WeaponPreference = famas
	WeaponPreference = galil
	WeaponPreference = mp5
End

// 释义：
// Template Shield              ;盾牌手模板（Shield）
//	WeaponPreference = m4a1     ;武器偏好（m4a1）以防盾牌不被允许使用
//	WeaponPreference = ak47     ;武器偏好（ak47）
//	WeaponPreference = famas    ;武器偏好（famas）
//	WeaponPreference = galil    ;武器偏好（galil）
//	WeaponPreference = mp5      ;武器偏好（mp5）
// End
//----------------------------------------------------------------------------

//----------------------------------------------------------------------------
Template Spray
	WeaponPreference = p90
	WeaponPreference = tmp
	WeaponPreference = mac10
	WeaponPreference = mp5
End

// 释义：
// Template Spray               ;侦察兵模板（Spray）
//	WeaponPreference = m4a1     ;武器偏好（m4a1）
//	WeaponPreference = ak47     ;武器偏好（ak47）
//	WeaponPreference = famas    ;武器偏好（famas）
//	WeaponPreference = galil    ;武器偏好（galil）
//	WeaponPreference = mp5      ;武器偏好（mp5）
// End
//----------------------------------------------------------------------------


//----------------------------------------------------------------------------
// （二）技能模板
//----------------------------------------------------------------------------
Template Elite
	Skill = 100
	Aggression = 100
	ReactionTime = 0.2
	Cost = 4
	Difficulty = EXPERT
	VoicePitch = 85
End

// 释义：
// Template Elite               ;精英级模板（Elite）
//	Skill = 100                 ;技能（100）
//	Aggression = 100            ;攻击性（100）
//	ReactionTime = 0.2          ;反应时间（0.2）
//	Cost = 4                    ;购买装备武器的花费（4）
//  Difficulty = EXPERT         ;难度级别（专家级）
//	VoicePitch = 85             ;语音大小（85）
// End
//----------------------------------------------------------------------------

//----------------------------------------------------------------------------
Template Expert
	Skill = 90
	Aggression = 90
	ReactionTime = 0.2
	Cost = 4
	Difficulty = EXPERT
	VoicePitch = 88
End

// 释义：
// Template Expert             ;专家级模板（Expert）
//	Skill = 90                 ;技能（90）
//	Aggression = 90            ;攻击性（90）
//	ReactionTime = 0.2         ;反应时间（0.2）
//	Cost = 4                   ;购买装备武器的花费（4）
//  Difficulty = EXPERT        ;难度级别（专家级）
//	VoicePitch = 88            ;语音大小（88）
// End
//----------------------------------------------------------------------------

//----------------------------------------------------------------------------
Template VeryHard
	Skill = 80
	Aggression = 80
	ReactionTime = 0.25
	Cost = 3
	Difficulty = HARD
	VoicePitch = 92
End

// 释义：
// Template VeryHard           ;超难级模板（VeryHard）
//	Skill = 80                 ;技能（80）
//	Aggression = 80            ;攻击性（80）
//	ReactionTime = 0.25        ;反应时间（0.25）
//	Cost = 3                   ;购买装备武器的花费（3）
//  Difficulty = HARD          ;难度级别（HARD）
//	VoicePitch = 92            ;语音大小（92）
// End
//----------------------------------------------------------------------------

//----------------------------------------------------------------------------
Template Hard
	Skill = 75
	Aggression = 75
	ReactionTime = 0.25
	Cost = 3
	Difficulty = HARD
	VoicePitch = 94
End

// 释义：
// Template Hard               ;困难级模板（Hard）
//	Skill = 75                 ;技能（75）
//	Aggression = 75            ;攻击性（75）
//	ReactionTime = 0.25        ;反应时间（0.25）
//	Cost = 3                   ;购买装备武器的花费（3）
//  Difficulty = HARD          ;难度级别（HARD）
//	VoicePitch = 94            ;语音大小（94）
// End
//----------------------------------------------------------------------------

//----------------------------------------------------------------------------
Template Tough
	Skill = 60
	Aggression = 60
	ReactionTime = 0.3		// 0.2 - 0.4
	AttackDelay = 0.35		// 0.3 - 0.4
	Cost = 2
	Difficulty = NORMAL+HARD
	VoicePitch = 96
End

// 释义：
// Template Tough              ;艰难级模板（Hard）
//	Skill = 60                 ;技能（60）
//	Aggression = 60            ;攻击性（60）
//	ReactionTime = 0.3         ;反应时间（0.3）0.2 - 0.4
//  AttackDelay = 0.35         ;攻击延迟（0.35）0.3 - 0.4
//	Cost = 2                   ;购买装备武器的花费（2）
//  Difficulty = NORMAL+HARD   ;难度级别（NORMAL+HARD）
//	VoicePitch = 96            ;语音大小（96）
// End
//----------------------------------------------------------------------------

//----------------------------------------------------------------------------
Template Normal
	Skill = 50
	Aggression = 50
	ReactionTime = 0.4		// 0.2 - 0.4
	AttackDelay = 0.7			// 0.3 - 0.4
	Cost = 2
	Difficulty = NORMAL
End

// 释义：
// Template Normal             ;普通级模板（Normal）
//	Skill = 50                 ;技能（50）
//	Aggression = 50            ;攻击性（50）
//	ReactionTime = 0.4         ;反应时间（0.4）0.2 - 0.4
//  AttackDelay = 0.7          ;攻击延迟（0.7）0.3 - 0.4
//	Cost = 2                   ;购买装备武器的花费（2）
//  Difficulty = NORMAL        ;难度级别（NORMAL）
// End
//----------------------------------------------------------------------------

//----------------------------------------------------------------------------
Template Fair
	Skill = 25
	Aggression = 30
	ReactionTime = 0.4		// 0.25 - 0.5
	AttackDelay = 1.0			// 1.0 - 1.5f
	Cost = 1
	Difficulty = EASY+NORMAL
	VoicePitch = 105
End

// 释义：
// Template Fair               ;公平级模板（ Fair）
//	Skill = 25                 ;技能（25）
//	Aggression = 30            ;攻击性（30）
//	ReactionTime = 0.4         ;反应时间（0.4）0.25 - 0.5
//  AttackDelay = 1.0          ;攻击延迟（1.0）1.0 - 1.5f
//	Cost = 1                   ;购买装备武器的花费（1）
//  Difficulty = EASY+NORMAL   ;难度级别（EASY+NORMAL）
//	VoicePitch = 105           ;语音大小（105）
// End
//----------------------------------------------------------------------------

//----------------------------------------------------------------------------
Template Easy
	Skill = 0
	Aggression = 20
	ReactionTime = 0.5		// 0.25 - 0.5
	AttackDelay = 1.5			// 1.0 - 1.5f
	Cost = 1
	Difficulty = EASY
	VoicePitch = 110
End

// 释义：
// Template Easy               ;休闲级模板（Easy）
//	Skill = 20                 ;技能（20）
//	Aggression = 20            ;攻击性（20）
//	ReactionTime = 0.5         ;反应时间（0.5）
//  AttackDelay = 1.5          ;攻击延迟（1.5）
//	Cost = 1                   ;购买装备武器的花费（1）
//  Difficulty = EASY          ;难度级别（EASY）
//	VoicePitch = 110           ;语音大小（110）
// End
//----------------------------------------------------------------------------


//----------------------------------------------------------------------------
// 
// 自定义机器人（可定义机器人名、所持武器、皮肤、难度等）
//
//-------------------------------------------
// 语法定义（范例）
// 
// 技能模板类型+武器模板类型 机器人名
// Tough+Power 毛毛的老公       ;自定义一个艰难级的机枪手机器人毛毛的老公 
//
//	WeaponPreference = awp     ;1级优先武器
//	WeaponPreference = m4a1    ;2级优先武器
//	WeaponPreference = ak47    ;3级优先武器
//	WeaponPreference = famas   ;4级优先武器
//	WeaponPreference = mp5     ;5级优先武器
//	WeaponPreference = deagle  ;6级优先武器
//
//	Teamwork = 70              ;团队合作
//	Aggression = 50            ;攻击性
//
//	Skin = 3                   ;角色类型
//	VoicePitch = 90            ;语音大小
// End
//
// 通过以上自定义，可定制出一个艰难级的机枪手机器人毛毛的老公 
// 其团队合作能力为70，攻击性为50.
//-------------------------------------------
//----------------------------------------------------------------------------

